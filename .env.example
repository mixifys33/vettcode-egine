# Add up to 3 OpenRouter API keys for parallel scanning (round-robin load balancing)
OPENROUTER_API_KEY_1=sk-or-v1-your-key-here
OPENROUTER_API_KEY_2=sk-or-v1-your-second-key
OPENROUTER_API_KEY_3=sk-or-v1-your-third-key

# Optional: comma-separated fallback if you prefer one variable
# OPENROUTER_API_KEYS=key1,key2,key3

# Default free models (comma-separated fallback chain)
OPENROUTER_MODELS=openrouter/free,deepseek/deepseek-chat-v3-0324:free,qwen/qwen-2.5-coder-32b-instruct:free

# Site metadata for OpenRouter rankings (optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API URL for seller authentication
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000











